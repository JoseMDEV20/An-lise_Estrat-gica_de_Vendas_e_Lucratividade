      <aliases enabled='yes' />
      <column caption='Loss alert' datatype='string' name='[Calculation_0026441640251392]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Lucro]) &lt; 0 THEN &quot;Critical&quot; ELSE &quot;Healthy&quot; END' />
      </column>
      <column caption='Sales previous month' datatype='real' name='[Calculation_0026441645633538]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(SUM([Valor da venda]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Growth MoM %' datatype='real' name='[Calculation_0026441646387203]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Valor da venda]) - [Calculation_0026441645633538]) / [Calculation_0026441645633538]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Sales Ticket' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_0026441679781892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(SUM([Valor da venda]) / SUM([Quantidade]))' />
      </column>
      <column caption='Profit margin %' datatype='real' name='[Calculation_0026441680220165]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Lucro]) / SUM([Valor da venda])' />
      </column>
      <column caption='Impact of the discount' datatype='real' name='[Calculation_0026441681154054]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Desconto %])' />
      </column>
      <column caption='Quantity of orders' datatype='integer' name='[Calculation_0245245520699392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Código Nota Fiscal])' />
      </column>
      <column caption='Average Orders Ticket' datatype='real' name='[Calculation_0245245524320258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(SUM([Valor da venda]) / [Calculation_0245245520699392])&#13;&#10;// This code calculates the average orders ticket' />
      </column>
      <column caption='Higher value' datatype='real' name='[Calculation_0245245550317571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Valor da venda])' />
      </column>
      <column caption='Lowest value' datatype='real' name='[Calculation_0245245551312900]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Valor da venda])' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_0245245553385477]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='RANK(SUM([Valor da venda]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Calculation Parameter Rank' datatype='boolean' name='[Calculation_0245245554905094]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0245245553385477] &lt;= [Parameters].[Parameter 2] THEN TRUE ELSE FALSE END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top' datatype='string' name='[Calculation_0245245558943751]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0245245553385477] &lt;= 3 THEN &apos;Top 5&apos; ELSEIF [Calculation_0245245553385477] &lt;= 10 THEN &apos;Top 6&apos; ELSEIF [Calculation_0245245553385477] &lt;= 15 THEN &apos;Top 15&apos; END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Data Dinâamica' datatype='datetime' name='[Calculation_0989888390754305]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;    WHEN &apos;Day&apos; THEN DATETRUNC(&apos;day&apos;, [Data do Pedido])&#13;&#10;    WHEN &apos;Week&apos; THEN DATETRUNC(&apos;week&apos;, [Data do Pedido])&#13;&#10;    WHEN &apos;Month&apos; THEN DATETRUNC(&apos;month&apos;, [Data do Pedido])&#13;&#10;END' />
      </column>
      <column caption='DT Month' datatype='datetime' default-format='*m/d/yyyy' name='[Calculation_1183129648734208]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Data do Pedido])' />
      </column>
      <column caption='DT Day' datatype='datetime' name='[Calculation_1183129672736771]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;day&apos;,[Data do Pedido])' />
      </column>
      <column caption=' SLA' datatype='integer' name='[Calculation_1183129676677124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Data do Pedido],[Data de Envio])' />
      </column>
      <column caption='Test' datatype='string' name='[Calculation_1183129680965637]' role='dimension' type='nominal'>
